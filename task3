-- Create Orders Table
drop table orders;
CREATE TABLE orders (
    id INT PRIMARY KEY,
    product_name VARCHAR(50),
    quantity INT,
    price DECIMAL(10,2)
);

-- Insert 5 Orders with Different Values
INSERT INTO orders VALUES
(1, 'Apple Juice', 5, 120.00),
(2, 'Banana Chips', 2, 80.00),
(3, 'Avocado Salad', 3, 450.00),
(4, 'Orange Cake', 1, 600.00),
(5, 'Almond Milk', 4, 300.00);

-- Select Orders Where Quantity > 2
SELECT *
FROM orders
WHERE quantity > 2;

-- Select Orders Where Price Between 100 and 500
SELECT *
FROM orders
WHERE price BETWEEN 100 AND 500;

-- Fetch Orders with Product Name Starting with 'A'
SELECT *
FROM orders
WHERE product_name LIKE 'A%';

-- Fetch Orders Sorted by Quantity Descending
SELECT *
FROM orders
ORDER BY quantity DESC;

-- Find Average Order Price
SELECT AVG(price) AS average_price
FROM orders;

-- Group Orders by Product Name and Show Total Sales
SELECT
    product_name,
    SUM(quantity * price) AS total_sales
FROM orders
GROUP BY product_name;

-- Sort Grouped Data by Total Sales Descending
SELECT
    product_name,
    SUM(quantity * price) AS total_sales
FROM orders
GROUP BY product_name
ORDER BY total_sales DESC;


