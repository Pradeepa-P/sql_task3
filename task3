-- Create Events Table
CREATE TABLE events (
    id INT PRIMARY KEY,
    event_name VARCHAR(100),
    event_date DATE
);

-- Insert Events with Different Dates
INSERT INTO events VALUES
(1, 'Music Fest', '2026-06-15'),
(2, 'Tech Conference', '2026-07-20'),
(3, 'Sports Day', '2026-08-10');

-- Display Current Date & Time
SELECT NOW() AS current_datetime;

-- Format Event Date Using DATE_FORMAT()
SELECT
    event_name,
    DATE_FORMAT(event_date, '%d-%m-%Y') AS formatted_date
FROM events;

-- Extract YEAR and MONTH from Event Date
SELECT
    event_name,
    YEAR(event_date) AS event_year,
    MONTH(event_date) AS event_month
FROM events;

-- Use CONCAT() to Combine Event Name and Event Date
SELECT
    CONCAT(event_name, ' - ', event_date) AS event_details
FROM events;

